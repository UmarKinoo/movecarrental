# BookCars API (server-side & build-time for public vars)
BOOKCARS_API_URL=http://localhost:4002
BOOKCARS_DEFAULT_SUPPLIER_ID=

NEXT_PUBLIC_SITE_NAME="Move Car Rental"
NEXT_PUBLIC_DEFAULT_LANGUAGE=en
NEXT_PUBLIC_DEFAULT_CURRENCY=USD
NEXT_PUBLIC_BOOKCARS_BASE_CURRENCY=USD

NEXT_PUBLIC_BOOKCARS_CDN_CARS=http://localhost:4002/cdn/bookcars/cars
NEXT_PUBLIC_BOOKCARS_CDN_USERS=http://localhost:4002/cdn/bookcars/users
NEXT_PUBLIC_BOOKCARS_CDN_LICENSES=http://localhost:4002/cdn/bookcars/licenses

# Stripe Embedded Checkout: publishable key (backend holds secret key)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# PayPal (when NEXT_PUBLIC_PAYMENT_GATEWAY=PayPal)
NEXT_PUBLIC_PAYMENT_GATEWAY=Stripe
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# Optional reCAPTCHA v3 site key (must match backend BC_RECAPTCHA_SECRET when enabled)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Map default view (locations page)
NEXT_PUBLIC_MAP_LATITUDE=34.0268755
NEXT_PUBLIC_MAP_LONGITUDE=1.65284
NEXT_PUBLIC_MAP_ZOOM=5

# Important: set BookCars backend BC_FRONTEND_HOST to this app’s public URL (e.g. http://localhost:3000)
# so Stripe return_url and activation emails point to Next.js routes like /checkout-session/{SESSION_ID} and /activate.
